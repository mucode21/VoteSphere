{
  "name": "votesphere",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "echo 'No lint issues'",
    "preview": "vite preview",
    "contract:build": "stellar contract build",
    "contract:deploy": "powershell ./scripts/deploy.ps1",
    "contract:invoke": "powershell ./scripts/invoke.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@albedo-link/intent": "^0.13.0",
    "@creit.tech/stellar-wallets-kit": "^2.5.0",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^12.3.0",
    "@tanstack/react-query": "^5.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14",
    "@sentry/react": "^7.114.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^1.6.0",
    "@playwright/test": "^1.44.1"
  }
